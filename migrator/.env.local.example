# .env.local.example
# Variables de entorno para ejecutar el migrator contra los contenedores locales
# Copia este archivo a .env.local y ajusta según necesites
# Uso: source .env.local && make run

# PostgreSQL local (puerto 5433 para no conflicto con el postgres del dev-environment)
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_DB=edugo
POSTGRES_USER=edugo
POSTGRES_PASSWORD=edugo123
POSTGRES_SSLMODE=disable

# MongoDB local (puerto 27018 para no conflicto con el mongo del dev-environment)
MONGO_HOST=localhost
MONGO_PORT=27018
MONGO_USER=edugo
MONGO_PASSWORD=edugo123
MONGO_DB_NAME=edugo

# Flags de control (descomenta según necesidad)
# FORCE_MIGRATION=true       # Recrear BD desde cero (BORRA DATOS)
# APPLY_MOCK_DATA=false      # Omitir datos de desarrollo
# POSTGRES_ONLY=true         # Solo migrar PostgreSQL
# MONGO_ONLY=true            # Solo migrar MongoDB
# STATUS_ONLY=true           # Solo ver estado, no migrar
